---
import Layout from "../layouts/Layout.astro";

const description =
  "OK Code is the calm workspace for coding agents — threads, diffs, preview, PR review, release actions, and themes in one focused desktop + web app.";

const heroTabs = [
  {
    id: "chat",
    label: "Chat",
    kicker: "Long-running threads",
    title: "Keep serious coding conversations coherent.",
    body:
      "OK Code gives agents a real workspace instead of a disposable prompt box — with durable threads, project-aware context, and room to keep working.",
    bullets: ["Project-scoped threads", "Provider-aware models", "Less context sludge"],
    overlay: "Thread + agent workspace",
  },
  {
    id: "diffs",
    label: "Diffs",
    kicker: "See what changed",
    title: "Review code like a human, not a log parser.",
    body:
      "Diffs stay tied to the work. Scan the latest change, compare checkpoints, and understand what moved without swimming through terminal noise.",
    bullets: ["Latest vs all changes", "Cleaner review flow", "Built for real edits"],
    overlay: "Diff review built in",
  },
  {
    id: "preview",
    label: "Preview",
    kicker: "Preview locally",
    title: "Open localhost right beside the conversation.",
    body:
      "Launch your local app, keep the agent nearby, and iterate without bouncing across five windows just to verify one UI tweak.",
    bullets: ["Embedded localhost preview", "Desktop-friendly layout", "Faster fix / refresh loop"],
    overlay: "Preview without context switching",
  },
  {
    id: "pr-review",
    label: "PR Review",
    kicker: "Review work clearly",
    title: "Pull request review belongs in the workspace too.",
    body:
      "Bring review into the same place you think, diff, and ship — so feedback, code changes, and release decisions stay connected.",
    bullets: ["Dedicated PR review surface", "Sidebar navigation", "Less tab chaos"],
    overlay: "PR review surface",
  },
  {
    id: "release",
    label: "Release",
    kicker: "Ship from the same flow",
    title: "From coding thread to release action without leaving the app.",
    body:
      "Scripts, packaging, and release actions can live right next to the work, so shipping feels like part of the product instead of a separate ritual.",
    bullets: ["Project actions", "Release-friendly workflows", "Desktop packaging aware"],
    overlay: "Ship from one workspace",
  },
] as const;

const spotlightItems = [
  {
    id: "threads",
    label: "Threads",
    eyebrow: "Thinking space",
    title: "Durable agent threads that survive real work.",
    body:
      "Open a project, start a thread, and keep the session coherent while the work evolves. Great for long fixes, reviews, and iterative UI polish.",
    bullets: ["Project-scoped sessions", "Provider + model control", "Better continuity than one-shot chat"],
  },
  {
    id: "diffs",
    label: "Diffs",
    eyebrow: "Code visibility",
    title: "Diffs that explain the work instead of obscuring it.",
    body:
      "Compare changes without exposing raw runtime internals. OK Code is moving toward a human-first review flow, not debug sludge.",
    bullets: ["Latest / all changes", "Thread-aware change history", "Readable review UI"],
  },
  {
    id: "preview",
    label: "Preview",
    eyebrow: "Fast iteration",
    title: "Preview local apps inside the workspace.",
    body:
      "Useful for frontend and desktop workflows where validating UI state matters as much as generating the code itself.",
    bullets: ["Localhost preview", "Docked desktop surface", "Fewer context switches"],
  },
  {
    id: "pr-review",
    label: "PR Review",
    eyebrow: "Review surface",
    title: "Handle pull requests without leaving the product context.",
    body:
      "PR review in OK Code keeps code, comments, and release decisions tied together instead of scattering them across browser tabs.",
    bullets: ["Dedicated review page", "Sidebar entry point", "Pairs naturally with diffs"],
  },
  {
    id: "actions",
    label: "Actions",
    eyebrow: "Shipping tools",
    title: "Save the commands you actually use to ship.",
    body:
      "Project actions can become lightweight release, preview, and maintenance buttons — enough automation to help, not enough complexity to become a platform.",
    bullets: ["Saved commands", "Release-friendly actions", "Project-specific workflows"],
  },
  {
    id: "themes",
    label: "Themes",
    eyebrow: "Product personality",
    title: "A workspace with actual visual taste.",
    body:
      "Themes are part of the product story, not an afterthought. They can shape the app’s mood without sacrificing readability.",
    bullets: ["Signature themes", "Premium dark modes", "Future design identity"],
  },
] as const;

const themeIdeas = [
  {
    id: "iridescent-void",
    label: "Iridescent Void",
    vibe: "Futuristic, expensive, slightly alien",
    body:
      "True black with spectral cyan, violet, and magenta accents. Great flagship theme energy.",
    gradient: "linear-gradient(135deg, rgba(56,189,248,0.24), rgba(168,85,247,0.2) 45%, rgba(244,114,182,0.22))",
    border: "rgba(103, 232, 249, 0.36)",
    accent: "#67e8f9",
  },
  {
    id: "solar-witch",
    label: "Solar Witch",
    vibe: "Magical, cozy, ritualistic",
    body:
      "Obsidian with ember orange, candle gold, and smoky plum. Warm without becoming mushy.",
    gradient: "linear-gradient(135deg, rgba(251,146,60,0.26), rgba(217,70,239,0.16) 48%, rgba(253,224,71,0.18))",
    border: "rgba(251, 191, 36, 0.34)",
    accent: "#fbbf24",
  },
  {
    id: "deep-sea-terminal",
    label: "Deep Sea Terminal",
    vibe: "Submerged, dreamy, calm",
    body:
      "Abyss navy with bioluminescent aqua and sea-glass mint. Built for lower-stress long sessions.",
    gradient: "linear-gradient(135deg, rgba(34,211,238,0.18), rgba(59,130,246,0.18) 50%, rgba(45,212,191,0.24))",
    border: "rgba(94, 234, 212, 0.34)",
    accent: "#5eead4",
  },
] as const;
---

<Layout title="OK Code" {description}>
  <section class="hero">
    <div class="hero-copy">
      <div class="eyebrow">
        <span class="eyebrow-dot" aria-hidden="true"></span>
        Calm desktop + web workspace for coding agents
      </div>

      <h1 class="tagline">A focused home for coding agents, from thread to release.</h1>

      <p class="subtagline">
        OK Code brings long-running threads, diffs, preview, PR review, release actions,
        and desktop-grade control into one product — without turning the UI into a theme park.
      </p>

      <div class="hero-actions">
        <a
          id="download-btn"
          href="https://github.com/OpenKnots/okcode/releases"
          class="hero-button"
        >
          <svg class="hero-button-icon hero-button-icon--apple" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 814 1000" aria-hidden="true"><path fill="currentColor" d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"/></svg>
          <svg class="hero-button-icon hero-button-icon--windows" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 88 88" aria-hidden="true"><path fill="currentColor" d="m0 12.402 35.687-4.86.016 34.423-35.67.203zm35.67 33.529.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349-.011 41.34-47.318-6.678-.066-34.739z"/></svg>
          <svg class="hero-button-icon hero-button-icon--linux" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 295" aria-hidden="true"><path fill="currentColor" d="M63.213 215.474c-11.387-16.346-13.591-69.606 12.947-102.39C89.292 97.383 92.69 86.455 93.7 71.67c.734-16.805-11.846-66.851 35.537-70.616 48.027-3.857 45.364 43.526 45.088 68.596-.183 21.12 15.52 33.15 26.355 49.68 19.927 30.303 18.274 82.461-3.765 110.745-27.916 35.354-51.791 20.018-67.678 21.304-29.752 1.745-30.762 17.54-66.024-35.905"/></svg>
          <span id="download-label">Download now</span>
        </a>

        <a
          href="https://github.com/OpenKnots/okcode"
          target="_blank"
          rel="noopener noreferrer"
          class="secondary-button"
        >
          View on GitHub
        </a>
      </div>

      <div class="hero-meta">
        <a href="/download" class="other-platforms">Other platforms</a>
        <div class="hero-pills" aria-label="Product highlights">
          <span>Codex + Anthropic</span>
          <span>Threads + diffs</span>
          <span>Preview + PR review</span>
          <span>Desktop + web</span>
        </div>
      </div>
    </div>

    <div class="hero-visual" data-tab-group data-tab-default="chat" data-group-theme="hero">
      <div class="hero-glow hero-glow--pink"></div>
      <div class="hero-glow hero-glow--blue"></div>

      <div class="interactive-section-head">
        <p class="section-kicker">Explore the product</p>
        <div class="tab-row" role="tablist" aria-label="Hero preview tabs">
          {heroTabs.map((tab) => (
            <button
              type="button"
              class="tab-chip"
              data-tab-button
              data-tab-target={tab.id}
              role="tab"
              aria-selected={tab.id === "chat" ? "true" : "false"}
            >
              {tab.label}
            </button>
          ))}
        </div>
      </div>

      <div class="hero-showcase" data-hero-surface>
        <div class="screenshot-card">
          <div class="screenshot-chrome">
            <div class="traffic-lights" aria-hidden="true">
              <span></span><span></span><span></span>
            </div>
            <div class="chrome-label">OK Code</div>
            <div class="chrome-badge" data-hero-overlay>
              {heroTabs[0].overlay}
            </div>
          </div>
          <div class="screenshot-wrap">
            <img
              src="/screenshot.jpeg"
              alt="OK Code showing agent chat, diffs, and workflow controls."
              class="screenshot"
            />
          </div>
        </div>

        <div class="hero-detail-stack">
          {heroTabs.map((tab) => (
            <article
              class="hero-detail-panel"
              data-tab-panel={tab.id}
              hidden={tab.id === "chat" ? undefined : true}
            >
              <p class="section-kicker">{tab.kicker}</p>
              <h2>{tab.title}</h2>
              <p>{tab.body}</p>
              <ul class="detail-bullets">
                {tab.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>

      <div class="floating-card floating-card--left">
        <div class="floating-card-kicker">Why it feels different</div>
        <strong>Built for long-running agent work.</strong>
        <span>Threads, scripts, diffs, preview, and release actions live together instead of hiding behind plugins.</span>
      </div>

      <div class="floating-card floating-card--right">
        <div class="floating-card-kicker">Local-first power</div>
        <strong>Desktop when you need control.</strong>
        <span>Open previews, inspect changes, review PRs, and ship without leaving the product context.</span>
      </div>
    </div>
  </section>

  <section class="feature-grid" aria-label="Core product pillars">
    <article class="feature-card">
      <div class="feature-eyebrow">Thinking space</div>
      <h2>Threads that stay coherent.</h2>
      <p>
        Project-scoped sessions and model-aware workflows make OK Code feel like a real coding space,
        not a disposable prompt toy.
      </p>
    </article>

    <article class="feature-card">
      <div class="feature-eyebrow">Code visibility</div>
      <h2>Diffs and preview that explain the work.</h2>
      <p>
        Review the actual changes, open local UI, and keep the conversation tied to the code instead of buried in logs.
      </p>
    </article>

    <article class="feature-card">
      <div class="feature-eyebrow">Shipping</div>
      <h2>From thread to release.</h2>
      <p>
        PR review, project actions, and release-friendly workflows make shipping feel like part of the same product, not another app.
      </p>
    </article>
  </section>

  <section class="spotlight" data-tab-group data-tab-default="threads">
    <div class="spotlight-copy">
      <p class="section-kicker">Feature spotlight</p>
      <h2 class="section-title">Cover the whole product without forcing people to read a wall of text.</h2>
      <p class="section-body">
        Click through the core surfaces to understand what OK Code actually helps with — thinking, reviewing, previewing, and shipping.
      </p>
      <div class="spotlight-nav" role="tablist" aria-label="Feature spotlight tabs">
        {spotlightItems.map((item) => (
          <button
            type="button"
            class="spotlight-item"
            data-tab-button
            data-tab-target={item.id}
            role="tab"
            aria-selected={item.id === "threads" ? "true" : "false"}
          >
            <span class="spotlight-item-label">{item.label}</span>
            <span class="spotlight-item-meta">{item.eyebrow}</span>
          </button>
        ))}
      </div>
    </div>

    <div class="spotlight-panels">
      {spotlightItems.map((item) => (
        <article class="spotlight-panel" data-tab-panel={item.id} hidden={item.id === "threads" ? undefined : true}>
          <p class="section-kicker">{item.eyebrow}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
          <ul class="detail-bullets">
            {item.bullets.map((bullet) => (
              <li>{bullet}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="theme-section" data-tab-group data-tab-default="iridescent-void">
    <div class="theme-copy">
      <p class="section-kicker">Theme direction</p>
      <h2 class="section-title">A workspace with actual visual taste.</h2>
      <p class="section-body">
        Themes can make OK Code feel memorable in screenshots and long sessions — without turning readability into collateral damage.
      </p>
      <div class="tab-row" role="tablist" aria-label="Theme preview tabs">
        {themeIdeas.map((theme) => (
          <button
            type="button"
            class="tab-chip"
            data-tab-button
            data-tab-target={theme.id}
            role="tab"
            aria-selected={theme.id === "iridescent-void" ? "true" : "false"}
          >
            {theme.label}
          </button>
        ))}
      </div>
    </div>

    <div class="theme-preview-wrap">
      {themeIdeas.map((theme) => (
        <div class="theme-preview" data-tab-panel={theme.id} hidden={theme.id === "iridescent-void" ? undefined : true}>
          <div
            class="theme-preview-card"
            style={`--theme-gradient:${theme.gradient}; --theme-border:${theme.border}; --theme-accent:${theme.accent};`}
          >
            <div class="theme-preview-bar">
              <span></span><span></span><span></span>
            </div>
            <div class="theme-preview-body">
              <div class="theme-preview-sidebar"></div>
              <div class="theme-preview-main">
                <div class="theme-preview-line theme-preview-line--short"></div>
                <div class="theme-preview-line"></div>
                <div class="theme-preview-line theme-preview-line--accent"></div>
                <div class="theme-preview-line theme-preview-line--medium"></div>
              </div>
            </div>
          </div>
          <div class="theme-note">
            <h3>{theme.label}</h3>
            <p class="theme-vibe">{theme.vibe}</p>
            <p>{theme.body}</p>
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>

<script>
  import {
    fetchLatestRelease,
    RELEASES_URL,
    type Release,
  } from "../lib/releases";
  import { detectPlatform, pickAsset } from "../lib/download";

  function initDownloadButton() {
    const btn = document.getElementById("download-btn") as HTMLAnchorElement | null;
    const label = document.getElementById("download-label");
    if (!btn || !label) return;

    const platform = detectPlatform(navigator.userAgent);
    if (!platform) return;

    document.documentElement.dataset.platform = platform.os;
    label.textContent = platform.label;

    fetchLatestRelease()
      .then((release: Release) => {
        const url = pickAsset(release.assets ?? [], platform);
        if (url) {
          btn.href = url;
          btn.removeAttribute("target");
          btn.removeAttribute("rel");
        }
      })
      .catch(() => {
        btn.href = RELEASES_URL;
      });
  }

  function initTabGroups() {
    const groups = document.querySelectorAll<HTMLElement>("[data-tab-group]");
    groups.forEach((group) => {
      const defaultTab = group.getAttribute("data-tab-default");
      const buttons = Array.from(group.querySelectorAll<HTMLElement>("[data-tab-button]"));
      const panels = Array.from(group.querySelectorAll<HTMLElement>("[data-tab-panel]"));
      const heroOverlay = group.querySelector<HTMLElement>("[data-hero-overlay]");

      const activate = (id: string) => {
        buttons.forEach((button) => {
          const isActive = button.getAttribute("data-tab-target") === id;
          button.setAttribute("aria-selected", isActive ? "true" : "false");
          button.dataset.active = isActive ? "true" : "false";
        });

        panels.forEach((panel) => {
          const isActive = panel.getAttribute("data-tab-panel") === id;
          panel.hidden = !isActive;
          panel.dataset.active = isActive ? "true" : "false";
        });

        group.setAttribute("data-active-tab", id);

        if (heroOverlay) {
          const activePanel = panels.find((panel) => panel.getAttribute("data-tab-panel") === id);
          const overlayText = activePanel?.querySelector(".section-kicker")?.textContent;
          if (overlayText) {
            heroOverlay.textContent = overlayText;
          }
        }
      };

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const id = button.getAttribute("data-tab-target");
          if (id) activate(id);
        });
      });

      if (defaultTab) activate(defaultTab);
    });
  }

  initDownloadButton();
  initTabGroups();
</script>

<style>
  .main {
    width: 100%;
    padding-block: 3.5rem 5rem;
  }

  .hero,
  .feature-grid,
  .spotlight,
  .theme-section {
    width: 100%;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.08fr);
    gap: clamp(2.5rem, 5vw, 4.5rem);
    align-items: center;
    margin-bottom: 4.5rem;
  }

  .hero-copy {
    position: relative;
    z-index: 1;
  }

  .eyebrow,
  .hero-copy,
  .feature-grid,
  .spotlight,
  .theme-section {
    opacity: 0;
    animation: fade-in 0.8s ease-out forwards;
  }

  .hero-copy { animation-delay: 0.08s; }
  .feature-grid { animation-delay: 0.16s; }
  .spotlight { animation-delay: 0.22s; }
  .theme-section { animation-delay: 0.28s; }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.5rem 0.875rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
    color: var(--fg-muted);
    font-size: 0.82rem;
    margin-bottom: 1.2rem;
    backdrop-filter: blur(16px);
  }

  .eyebrow-dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #fb7185, #60a5fa);
    box-shadow: 0 0 0 6px rgba(255, 255, 255, 0.04);
  }

  .tagline {
    font-weight: 600;
    font-size: clamp(3rem, 6vw, 5.15rem);
    letter-spacing: -0.055em;
    line-height: 0.98;
    max-width: 11ch;
    margin: 0 0 1.25rem;
  }

  .subtagline,
  .section-body,
  .hero-detail-panel p,
  .spotlight-panel p,
  .theme-note p,
  .feature-card p {
    color: var(--fg-muted);
    line-height: 1.65;
  }

  .subtagline {
    font-size: clamp(1.05rem, 2vw, 1.24rem);
    max-width: 38rem;
    margin: 0 0 1.9rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-bottom: 1.2rem;
  }

  .hero-button,
  .secondary-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    min-height: 3.25rem;
    padding: 0.85rem 1.4rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.96rem;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease,
      background 0.25s ease;
  }

  .hero-button {
    background: linear-gradient(180deg, #ffffff, #ebebef);
    color: #09090b;
    box-shadow: 0 20px 50px rgba(255, 255, 255, 0.12);
  }

  .hero-button:hover,
  .secondary-button:hover,
  .tab-chip:hover,
  .spotlight-item:hover {
    transform: translateY(-1px);
  }

  .secondary-button,
  .tab-chip,
  .spotlight-item,
  .feature-card,
  .spotlight-panel,
  .theme-preview-card,
  .theme-note,
  .hero-detail-panel,
  .screenshot-card {
    backdrop-filter: blur(18px);
  }

  .secondary-button {
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
    color: var(--fg);
  }

  .hero-button-icon {
    display: none;
    width: 1em;
    height: 1em;
    flex-shrink: 0;
  }

  :global([data-platform="mac"]) .hero-button-icon--apple,
  :global([data-platform="win"]) .hero-button-icon--windows,
  :global([data-platform="linux"]) .hero-button-icon--linux {
    display: block;
  }

  .hero-meta {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .other-platforms {
    width: fit-content;
    font-size: 0.875rem;
    color: var(--fg-dim);
    text-decoration: underline;
    text-decoration-color: rgba(113, 113, 122, 0.36);
    text-underline-offset: 3px;
  }

  .hero-pills,
  .tab-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .hero-pills span,
  .tab-chip {
    display: inline-flex;
    align-items: center;
    min-height: 2.25rem;
    padding: 0.45rem 0.82rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    color: var(--fg-muted);
    font-size: 0.82rem;
  }

  .tab-chip {
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .tab-chip[data-active="true"],
  .spotlight-item[data-active="true"] {
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.09);
    color: var(--fg);
  }

  .interactive-section-head,
  .theme-copy {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    margin-bottom: 1.1rem;
  }

  .section-kicker,
  .feature-eyebrow,
  .floating-card-kicker {
